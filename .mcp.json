{
  "mcpServers": {
    "katailyst": {
      "type": "http",
      "url": "https://www.katailyst.com/mcp",
      "headers": {
        "Authorization": "Bearer ${KATAILYST_MCP_TOKEN}"
      }
    },
    "multimediaMastery": {
      "type": "http",
      "url": "https://multimediamastery.vercel.app/api/media/v1/mcp",
      "headers": {
        "Authorization": "Bearer ${MM_AGENT_TOKEN}"
      }
    },
    "axon-codegraph": {
      "command": "axon",
      "args": ["mcp"]
    }
  }
}
